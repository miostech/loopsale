# Banco de dados (MongoDB)
# Use MONGODB_URI ou DATABASE_URL como connection string
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=loopsale

# Sem MongoDB: UI e login demo (demo@loopsale.com / demo123) sem persistência
# Remova ou defina false quando for usar banco de verdade
DATABASE_DISABLED=true

# Opcional: credenciais do login demo (com DATABASE_DISABLED)
# DEMO_LOGIN_EMAIL=demo@loopsale.com
# DEMO_LOGIN_PASSWORD=demo123

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Cron (process-abandonment e process-scheduled-messages)
CRON_SECRET=generate-a-secret-for-cron

# Canais (Fase 2)
# Resend (email)
# RESEND_API_KEY=
# RESEND_FROM=LoopSale <noreply@seudominio.com>
# E-mail que recebe as solicitações de demo (formulário /agendamento-demo)
# DEMO_REQUEST_EMAIL=contato@seudominio.com
# Twilio (SMS e WhatsApp)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+5511999999999
# TWILIO_WHATSAPP_NUMBER=+14155238886  (número sandbox ou Business)

# IA - geração de mensagens (Fase 4)
# OPENAI_API_KEY=
