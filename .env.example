# Banco de dados (MongoDB)
# Use MONGODB_URI ou DATABASE_URL como connection string
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=loopsale

# Sem MongoDB: UI e login demo (demo@loopsale.com / demo123) sem persistência
# Remova ou defina false quando for usar banco de verdade
DATABASE_DISABLED=true

# Opcional: credenciais do login demo (com DATABASE_DISABLED)
# DEMO_LOGIN_EMAIL=demo@loopsale.com
# DEMO_LOGIN_PASSWORD=demo123

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Cron (process-abandonment e process-scheduled-messages)
CRON_SECRET=generate-a-secret-for-cron

# Super-admin (dono da LoopSale): e-mails que enxergam o painel /admin.
# Separados por vírgula.
SUPER_ADMIN_EMAILS=camilamota@mios.pt

# Custo por mensagem de WhatsApp paga à Meta, em EUR. Usado na margem do admin.
META_COST_PER_MESSAGE_EUR=0.0518
# Conversão EUR->BRL para trazer o custo Meta ao real (margem em R$).
EUR_BRL_RATE=6.2

# Canais (Fase 2)
# Resend (email)
# RESEND_API_KEY=
# RESEND_FROM=LoopSale <noreply@seudominio.com>
# E-mail que recebe as solicitações de demo (formulário /agendamento-demo)
# DEMO_REQUEST_EMAIL=contato@seudominio.com
# Twilio (SMS e WhatsApp)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+5511999999999
# TWILIO_WHATSAPP_NUMBER=+14155238886  (número sandbox ou Business)

# IA - geração de mensagens (Fase 4)
# OPENAI_API_KEY=

# Pagamentos / Assinaturas (Stripe)
# Chave secreta da API (sk_live_... ou sk_test_...)
# STRIPE_SECRET_KEY=
# Segredo do endpoint de webhook (whsec_...) — aponte o webhook para /api/webhooks/stripe
# STRIPE_WEBHOOK_SECRET=
# Price IDs recorrentes criados no painel do Stripe (um por plano pago)
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ESCALA=price_...
# STRIPE_PRICE_ENTERPRISE=price_...
# Add-on de atendimento gerenciado (mensalidade fixa)
# STRIPE_PRICE_SUPPORT=price_...
# Taxa USD->BRL para converter a comissão do Free (padrão 5.40)
# USD_BRL_RATE=5.40
